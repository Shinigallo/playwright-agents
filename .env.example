# ============================================================
# LLM PROXY — Configurazione
# ============================================================
# Provider: "gemini" (default) oppure "openai" (Ollama, LM Studio,
# OpenAI, Azure, opencode, e qualsiasi API compatibile OpenAI).
# ============================================================
LLM_PROVIDER=gemini

# ── Provider: Gemini (default) ──────────────────────────────────
# Chiavi API Gemini multiple — separate da virgola
GEMINI_API_KEYS=your-key-1, your-key-2, your-key-3
MODEL=gemini-2.0-flash

# ── Provider: OpenAI-compatible ────────────────────────────────
# Per Ollama locale:
#   LLM_PROVIDER=openai
#   OPENAI_API_BASE_URL=http://host.docker.internal:11434/v1
#   OPENAI_API_KEYS=ollama-no-key-needed
#   OPENAI_API_MODEL=llama3.1
#
# Per LM Studio:
#   OPENAI_API_BASE_URL=http://host.docker.internal:1234/v1
#   OPENAI_API_KEYS=lm-studio
#
# Per OpenAI (cloud):
#   OPENAI_API_BASE_URL=https://api.openai.com/v1
#   OPENAI_API_KEYS=sk-...
#
# Per opencode / altri server compatibili:
#   OPENAI_API_BASE_URL=http://host.docker.internal:PORT/v1
#   OPENAI_API_KEYS=tuo-token
#
# Chiavi API multiple (comma-separated, opzionale per rotazione)
OPENAI_API_KEYS=
# URL base dell'API (senza /chat/completions finale)
OPENAI_API_BASE_URL=http://localhost:11434/v1
# Modello predefinito per OpenAI-compatible
OPENAI_API_MODEL=llama3.1

# ── SAP Configuration (optional) ────────────────────────────────
# SAP credentials per test automatizzati
# SAP_USERNAME=your-sap-user
# SAP_PASSWORD=your-sap-password
# SAP_TYPE=auto|fiori|webgui
