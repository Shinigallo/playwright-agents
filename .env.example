# Chiavi API Gemini multiple — separate da virgola
# Rotazione automatica: quando una chiave ha quota ecceduta (429),
# il proxy passa automaticamente alla chiave successiva.
GEMINI_API_KEYS=key1,key2,key3

# Model options:
# gemini-2.0-flash    → fast, cheap (default)
# gemini-2.5-pro      → smarter, slower
# gemini-3.0-ultra    → most capable
MODEL=gemini-2.0-flash
