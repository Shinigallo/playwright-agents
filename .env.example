# Chiavi API Gemini multiple — separate da virgola
# Pattern di rotazione: quando una chiave ha quota ecceduta,
# il proxy ruota automaticamente alla chiave successiva.
GEMINI_API_KEYS=your-key-1, your-key-2, your-key-3

# Model options:
# gemini-2.0-flash    → fast, cheap (default)
# gemini-2.5-pro      → smarter, slower
# gemini-3.0-ultra    → most capable
MODEL=gemini-2.0-flash
